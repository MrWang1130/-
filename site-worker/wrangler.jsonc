{
  "name": "qwerty-site",
  "main": "src/index.js",
  "compatibility_date": "2025-12-01",
  "routes": [
    {
      "pattern": "wk113.xyz",
      "custom_domain": true
    },
    {
      "pattern": "www.wk113.xyz",
      "custom_domain": true
    }
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "../public",
    "not_found_handling": "single-page-application"
  }
}
